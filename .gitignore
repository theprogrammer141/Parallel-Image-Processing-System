# ── Compiled binaries ─────────────────────────────────────────────────────────
build/

# ── Test images (large files — regenerated by 'make test_image') ─────────────
test_images/

# ── Generated results (images, plots, merged CSV) ─────────────────────────────
results/images/
results/plots/
results/data/all_results.csv

# Individual benchmark CSVs are kept so results can be reviewed on GitHub.
# Uncomment the line below to exclude them as well:
# results/data/

# Benchmark temporary repeat-run cache
results/data/.runs/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── C++ object files / dependency files (if ever generated separately) ────────
*.o
*.d
*.a
*.so
